# ───────────────────────────────────────────────
# Data — never commit raw, processed, or scraped data
# ───────────────────────────────────────────────
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ───────────────────────────────────────────────
# Models — large binary artifacts (250–600 MB total)
# ───────────────────────────────────────────────
models/cbf/*
models/cf/*
models/sentiment/*
!models/cbf/.gitkeep
!models/cf/.gitkeep
!models/sentiment/.gitkeep

# Blanket ignore of all serialized model files
*.pkl
*.bin
*.joblib
*.h5
*.onnx

# ───────────────────────────────────────────────
# Environment & Secrets
# ───────────────────────────────────────────────
.env
.env.local
.env.*.local

# ───────────────────────────────────────────────
# Python bytecode, cache, and temporary files
# ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ───────────────────────────────────────────────
# Jupyter & Notebook artifacts
# ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ───────────────────────────────────────────────
# MLflow & experiment tracking
# ───────────────────────────────────────────────
mlruns/
mlruns.*

# ───────────────────────────────────────────────
# IDE / Editor files
# ───────────────────────────────────────────────
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*~

# ───────────────────────────────────────────────
# OS-specific files
# ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# ───────────────────────────────────────────────
# Testing / Coverage
# ───────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.pytest_cache/

# ───────────────────────────────────────────────
# Logs & temporary files
# ───────────────────────────────────────────────
*.log
*.logs
*.tmp
*.bak
*.backup

# ───────────────────────────────────────────────
# Docker local overrides
# ───────────────────────────────────────────────
docker-compose.override.yml
docker-compose.*.yml

# ───────────────────────────────────────────────
# Optional: large external caches (if not versioned)
# ───────────────────────────────────────────────
# data/external/*.json   # Uncomment only if you decide NOT to commit tmdb_metadata_cache.json / wikipedia_plots.json